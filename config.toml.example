# aish configuration file
# Default path: ~/.aish/config.toml

# Global system prompt (default)
system_prompt = "あなたはLinuxサーバ管理の専門家です。SSHセッションの内容を把握しています。"

# AI response language (default: "Japanese", empty to disable)
language = "Japanese"

# Display settings
# Colors: ANSI escape sequences (use \u001B for ESC in TOML)
#         e.g. "\u001B[36m" (cyan fg), "\u001B[43m" (yellow bg), "\u001B[38;5;208m" (256-color)
#         fg+bg combined: "\u001B[38;5;208;48;5;238m"
#         or "" (empty) for terminal default
[display]
shell_prefix_label = "[aish]"                                  # default: "[aish]" — PS1 shell prompt prefix
shell_prefix_color = "\u001B[38;5;216m"                        # default: "\u001B[38;5;216m" (light orange)
header_color = "\u001B[38;5;208m"                              # default: "\u001B[38;5;208m" (orange) — startup banner
prompt_label = "[aish]"                                        # default: "[aish]" — aish prompt (Ctrl+/) label
prompt_color = "\u001B[38;5;208;48;2;50;35;20m"                # default: orange text, dark brown bg
thinking_message = "Thinking..."                               # default: "Thinking..."
thinking_color = "\u001B[38;5;208m"                            # default: "\u001B[38;5;208m" (orange)
ai_color = "\u001B[38;5;216m"                                  # default: "\u001B[38;5;216m" (light orange)
input_color = ""                                               # default: "" (terminal default)
confirm_color = "\u001B[38;5;228;48;5;239m"                    # default: pale yellow text, gray bg

# Logging settings
# Log Claude Code CLI commands and responses
[log]
enabled = false                                                # default: false
path = "~/.aish/logs/claude-code.log"                          # default: "~/.aish/logs/claude-code.log"

# Host-specific settings (not yet implemented)
# - patterns: OR match (any pattern matches), glob wildcards supported
# - First match wins (evaluated top to bottom)
# - Falls back to global system_prompt if no match

# Web servers
[[hosts]]
patterns = ["web*.example.com", "nginx.example.com", "apache.example.com"]
system_prompt = "あなたはWebサーバの専門家です。"

# DB servers
[[hosts]]
patterns = ["db*.example.com", "postgres-*"]
system_prompt = "あなたはデータベース管理の専門家です。"

# Bastion host
[[hosts]]
patterns = ["bastion.example.com"]
system_prompt = "あなたは踏み台サーバの管理者です。"
