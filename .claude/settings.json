{
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "model": "opus",
  "effort": "auto",
  "permissions": {
    "acceptEdits": "auto"
  },
  "allowedTools": [
    "Bash(npm run build)",
    "Bash(npm test)",
    "Bash(git log)",
    "Bash(ls *)",
    "Bash(cat *)",
    "Bash(cargo *)"
  ],
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  }
}
